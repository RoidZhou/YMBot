uint8                       up_limb_task_type   # 上肢任务类型 0：末端变化笛卡尔  1：关节变化  2：预设动作变化  3：夹爪动作 4:直线运动规划
geometry_msgs/PoseStamped   position            # 0 笛卡尔坐标下 导航点  -- 任务类型是0时候
float64[]                   place_joint_list    # 1：关节变化，数据列表  关节1、关节2、关节3......
uint8                       action_fixed        # 2: 预设动作变化，标志位，0--动作0  1---动作1
uint8                       left_and_right_select          # 3: 左右选择  0--左  1--右
---
bool                        success            #是否成功           
string                      message            #消息反馈  --失败原因 成功了 啥的........